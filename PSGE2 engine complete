class EdgeMetric:
    @staticmethod
    def compute_edge_length(coords_a: np.ndarray, coords_b: np.ndarray, metric: MetricType = MetricType.EUCLIDEAN, tensor: Optional[MetricTensor] = None) -> float:
        diff = coords_a - coords_b
        dim = len(diff)
        t = tensor if tensor else (MetricTensor.minkowski(dim) if metric == MetricType.LORENTZIAN else MetricTensor.euclidean(dim))
        val = t.interval_sq(diff)
        if val < 0:
            return float(np.sqrt(-val))
        return float(np.sqrt(val))


class SimplexVolume:
    @staticmethod
    def compute_volume(coords: Tuple[np.ndarray, ...], tensor: MetricTensor, metric_type: MetricType = MetricType.EUCLIDEAN, strict: bool = True) -> SimplexVolumeResult:
        v0 = coords[0]
        vectors = [v - v0 for v in coords[1:]]
        dim = len(vectors)
        
        gram = np.zeros((dim, dim))
        for i in range(dim):
            for j in range(dim):
                gram[i, j] = tensor.inner(vectors[i], vectors[j])

        rank = np.linalg.matrix_rank(gram)
        if rank < dim:
            if strict:
                raise GeometryError(f"Simplexe dégénéré : rang de la matrice de Gram ({rank}) inférieur à la dimension ({dim}).")
            return SimplexVolumeResult(volume=0.0, gram_determinant=0.0, signature=GramSignature.DEGENERATE, is_valid=False)

        det = float(np.linalg.det(gram))
        
        if metric_type == MetricType.LORENTZIAN:
            if det > 0:
                sig = GramSignature.SPACELIKE
            elif det < 0:
                sig = GramSignature.TIMELIKE
            else:
                sig = GramSignature.DEGENERATE
        else:
            if det < 0:
                if strict:
                    raise GeometryError(f"Déterminant de Gram négatif ({det}) en métrique euclidienne.")
                return SimplexVolumeResult(volume=0.0, gram_determinant=det, signature=GramSignature.DEGENERATE, is_valid=False)
            sig = GramSignature.EUCLIDEAN

        volume = float(np.sqrt(abs(det)) / factorial(dim))
        return SimplexVolumeResult(volume=volume, gram_determinant=det, signature=sig, is_valid=True)


class FaceExtractor:
    @staticmethod
    def extract_face_coords(tet_coords: Tuple[np.ndarray, ...], face_vertices: Tuple[int, int, int], tet_vertices: Tuple[int, int, int, int]) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
        vertex_map = {tet_vertices[i]: tet_coords[i] for i in range(4)}
        return (vertex_map[face_vertices[0]], vertex_map[face_vertices[1]], vertex_map[face_vertices[2]])


class FaceNormalComputer:
    @staticmethod
    def compute_normal(face_coords: Tuple[np.ndarray, np.ndarray, np.ndarray], cell_orientation: OrientationSign) -> FaceOrientation:
        v0, v1, v2 = face_coords
        vec1 = v1 - v0
        vec2 = v2 - v0
        normal = np.cross(vec1, vec2)
        norm = np.linalg.norm(normal)
        if norm == 0:
            raise GeometryError("Dégénérescence géométrique : face de mesure nulle.")
        
        unit_normal = normal / norm
        return FaceOrientation(_normal=unit_normal, orientation_sign=cell_orientation)


class OrientationResolver:
    @staticmethod
    def resolve_outward(face_orientation: FaceOrientation, face_coords: Tuple[np.ndarray, np.ndarray, np.ndarray], opposite_vertex_coord: np.ndarray, metric: MetricType = MetricType.EUCLIDEAN) -> ResolvedFaceOrientation:
        if metric == MetricType.LORENTZIAN:
            is_outward = (face_orientation.orientation_sign == OrientationSign.POSITIVE)
        else:
            v0, v1, v2 = face_coords
            face_center = (v0 + v1 + v2) / 3.0
            outward_dir = face_center - opposite_vertex_coord
            is_outward = bool(np.dot(face_orientation.normal, outward_dir) >= 0)

        return ResolvedFaceOrientation(
            _normal=face_orientation.normal,
            orientation_sign=face_orientation.orientation_sign,
            outward=is_outward
        )


class DihedralAngleComputer:
    @staticmethod
    def compute_dihedral(norm1: np.ndarray, norm2: np.ndarray, tol: float = 1e-12) -> DihedralAngleResult:
        norm1_len = np.linalg.norm(norm1)
        norm2_len = np.linalg.norm(norm2)
        
        if norm1_len < tol or norm2_len < tol:
            return DihedralAngleResult(
                angle=0.0,
                raw_dot_product=0.0,
                is_clamped=False,
                is_degenerate=True
            )

        dot_val = float(np.dot(norm1, norm2) / (norm1_len * norm2_len))
        is_clamped = False
        
        if dot_val > 1.0:
            dot_val = 1.0
            is_clamped = True
        elif dot_val < -1.0:
            dot_val = -1.0
            is_clamped = True
            
        angle = float(np.pi - np.arccos(dot_val))
        is_degenerate = (abs(angle) < tol or abs(angle - np.pi) < tol)

        return DihedralAngleResult(
            angle=angle,
            raw_dot_product=dot_val,
            is_clamped=is_clamped,
            is_degenerate=is_degenerate
        )


class DualCellComputer:
    @staticmethod
    def compute_dual_volume(edge: Tuple[int, int], incident_cells: Tuple[IncidentCell, ...],
                            coords_provider: Optional[CoordinatesProvider] = None) -> float:
        """Mesure de la charnière pour l'action de Regge en 4D : l'aire (2-volume) de
        l'arête-charnière elle-même. En dimension 3, la charnière est une arête et sa
        « mesure » pertinente pour l'action de Regge est sa longueur.

        On retourne ici la longueur de l'arête, qui est la mesure de charnière correcte
        pour l'action de Regge tridimensionnelle S = sum_hinges L(hinge) * deficit(hinge).
        Sans coordonnées disponibles, on retombe sur 1.0 (mesure unité).
        """
        if coords_provider is None:
            return 1.0
        a, b = edge
        pa = coords_provider.vertex(a)
        pb = coords_provider.vertex(b)
        length = float(np.linalg.norm(pb - pa))
        return length if length > 0 else 1.0


class DeficitComputer:
    @staticmethod
    def _dihedral_at_hinge(cell: IncidentCell, hinge: Tuple[int, int], coords_provider: CoordinatesProvider) -> float:
        """Angle dièdre interne d'un tétraèdre le long de l'arête (charnière) `hinge`.

        Dans un 3-simplexe, l'angle dièdre le long d'une arête {a,b} est l'angle
        entre les deux faces triangulaires qui partagent cette arête. Il se calcule
        proprement à partir des deux sommets opposés {c,d} : on projette les vecteurs
        a->c et a->d sur le plan orthogonal à l'arête a->b, et l'angle entre ces
        projections est l'angle dièdre.
        """
        a, b = hinge
        # les deux autres sommets du tétraèdre (opposés à l'arête)
        others = [v for v in cell.simplex if v not in (a, b)]
        if len(others) != 2:
            raise GeometryError(
                f"Charnière {hinge} incompatible avec le simplexe {cell.simplex}."
            )
        c, d = others

        pa = coords_provider.vertex(a)
        pb = coords_provider.vertex(b)
        pc = coords_provider.vertex(c)
        pd = coords_provider.vertex(d)

        edge = pb - pa
        edge_norm = np.linalg.norm(edge)
        if edge_norm < 1e-15:
            raise GeometryError(f"Arête dégénérée {hinge} (longueur nulle).")
        e_hat = edge / edge_norm

        # projeter a->c et a->d sur le plan orthogonal à l'arête
        vc = (pc - pa) - np.dot(pc - pa, e_hat) * e_hat
        vd = (pd - pa) - np.dot(pd - pa, e_hat) * e_hat

        nc = np.linalg.norm(vc)
        nd = np.linalg.norm(vd)
        if nc < 1e-15 or nd < 1e-15:
            raise GeometryError(f"Projection dégénérée pour la charnière {hinge}.")

        cos_theta = float(np.dot(vc, vd) / (nc * nd))
        cos_theta = max(-1.0, min(1.0, cos_theta))  # clamp numérique
        return float(np.arccos(cos_theta))

    @classmethod
    def compute_hinge_deficit(cls, hinge: Tuple[int, int], incident_cells: Tuple[IncidentCell, ...], coords_provider: CoordinatesProvider) -> float:
        """Angle de déficit de Regge : delta = 2*pi - somme des dièdres autour de l'arête.

        C'est la mesure exacte de la courbure concentrée sur la charnière. Un déficit
        nul signifie que les tétraèdres se referment parfaitement autour de l'arête
        (espace localement plat) ; un déficit positif signale une courbure positive
        (frustration icosaédrique, Tests 16-19).
        """
        sum_dihedral = 0.0
        for cell in incident_cells:
            sum_dihedral += cls._dihedral_at_hinge(cell, hinge, coords_provider)
        return float(2.0 * np.pi - sum_dihedral)


class ReggeActionComputer:
    @staticmethod
    def compute_einstein_regge_action(curvature_reports: Tuple[CurvatureReport, ...]) -> float:
        return sum(report.hinge_measure * report.deficit_angle for report in curvature_reports)


