# ----------------------------------------------------------------------
# 1. Hiérarchie d'Exceptions Scientifiques robustes
# ----------------------------------------------------------------------
class PSGEError(Exception):
    """Classe de base pour toutes les erreurs spécifiques à PSGE II."""
    pass


class TopologyError(PSGEError):
    """Levée en cas d'incohérence ou d'invalidité du certificat topologique."""
    pass


class MetricError(PSGEError):
    """Levée en cas de dégénérescence métrique ou de signature invalide."""
    pass


class GeometryError(PSGEError):
    """Levée en cas d'échec de calcul géométrique (dégénérescence, rang insuffisant)."""
    pass


# ----------------------------------------------------------------------
# 2. États, Énumérations et Signes d'Orientation
# ----------------------------------------------------------------------
class GeometryStatus(Enum):
    INVALID = 0
    COMPUTED = 1
    FAILED = 2


class MetricType(Enum):
    EUCLIDEAN = "Euclidean"
    LORENTZIAN = "Lorentzian"


class OrientationSign(Enum):
    POSITIVE = 1
    NEGATIVE = -1

    @classmethod
    def from_value(cls, val: float) -> 'OrientationSign':
        return cls.POSITIVE if val >= 0 else cls.NEGATIVE


class GramSignature(Enum):
    EUCLIDEAN = "Euclidean"
    SPACELIKE = "Spacelike"
    TIMELIKE = "Timelike"
    DEGENERATE = "Degenerate"


# ----------------------------------------------------------------------
# 3. Tenseur Métrique Généralisé (Encapsulation stricte et copie défensive)
# ----------------------------------------------------------------------
@dataclass(frozen=True)
class MetricTensor:
    _matrix: np.ndarray

    def __post_init__(self):
        matrix = np.array(object.__getattribute__(self, "_matrix"), dtype=float, copy=True)
        matrix.setflags(write=False)
        object.__setattr__(self, "_matrix", matrix)

    def inner(self, u: np.ndarray, v: np.ndarray) -> float:
        """Produit scalaire généralisé g(u, v) = u^T G v."""
        return float(u.T @ self._matrix @ v)

    def interval_sq(self, u: np.ndarray) -> float:
        """Carré de l'intervalle d'espace-temps g(u, u)."""
        return self.inner(u, u)

    @classmethod
    def euclidean(cls, dim: int) -> 'MetricTensor':
        mat = np.eye(dim)
        return cls(mat)

    @classmethod
    def minkowski(cls, dim: int = 4) -> 'MetricTensor':
        mat = np.eye(dim)
        mat[0, 0] = -1.0
        return cls(mat)


