# 7. Collecteur de Statistiques et Pipeline d'Orchestration Pur
# ----------------------------------------------------------------------
class GeometryStatisticsCollector:
    @staticmethod
    def collect(certificate, coords_provider: CoordinatesProvider, tensor: MetricTensor, metric: MetricType) -> GeometryStatistics:
        """Collecte les mesures globales du maillage : volume total, longueurs d'arêtes,
        volumes de Gram par simplexe, et comptage des simplexes (valides / dégénérés)."""
        from itertools import combinations

        tetrahedra = getattr(certificate, "tetrahedra", None)
        if tetrahedra is None:
            return GeometryStatistics(0.0, (), (), 0, 0)

        total_volume = 0.0
        edge_set = set()
        edge_lengths_list = []
        gram_volumes_list = []
        num_simplices = 0
        num_ignored = 0

        for tet in tetrahedra:
            tet = tuple(tet)
            num_simplices += 1
            coords = tuple(coords_provider.vertex(v) for v in tet)
            try:
                vol_result = SimplexVolume.compute_volume(coords, tensor, metric, strict=False)
            except GeometryError:
                num_ignored += 1
                continue
            if not vol_result.is_valid:
                num_ignored += 1
                continue
            total_volume += vol_result.volume
            gram_volumes_list.append(vol_result.volume)
            # longueurs d'arêtes (chaque arête comptée une fois)
            for a, b in combinations(sorted(tet), 2):
                if (a, b) not in edge_set:
                    edge_set.add((a, b))
                    pa, pb = coords_provider.vertex(a), coords_provider.vertex(b)
                    edge_lengths_list.append(float(np.linalg.norm(pb - pa)))

        return GeometryStatistics(
            total_volume=total_volume,
            edge_lengths=tuple(edge_lengths_list),
            gram_volumes=tuple(gram_volumes_list),
            num_simplices=num_simplices,
            num_degenerate_simplices_ignored=num_ignored
        )


class MeshTraversal:
    @staticmethod
    def extract_hinges_and_cells(certificate, coords_provider: Optional[CoordinatesProvider] = None) -> Tuple[HingeTraversalResult, ...]:
        """Parcourt le maillage : pour chaque arête interne (charnière), rassemble tous
        les tétraèdres qui la contiennent.

        Le `certificate` doit exposer `tetrahedra` : un itérable de 4-uplets de sommets.
        Chaque tétraèdre {v0,v1,v2,v3} possède 6 arêtes ; on regroupe les tétraèdres
        par arête partagée pour reconstituer les charnières et leurs cellules incidentes.
        """
        from itertools import combinations

        tetrahedra = getattr(certificate, "tetrahedra", None)
        if tetrahedra is None:
            return ()

        # regrouper les tétraèdres par arête (charnière canonique : sommets triés)
        hinge_to_cells: Dict[Tuple[int, int], list] = {}
        for tet in tetrahedra:
            tet = tuple(tet)
            for a, b in combinations(sorted(tet), 2):
                hinge = (a, b)
                # sommets opposés à l'arête dans ce tétraèdre
                opposite = tuple(v for v in tet if v not in (a, b))
                # faces du tétraèdre incidentes à l'arête (les 2 faces contenant a et b)
                faces = tuple(
                    tuple(sorted(f)) for f in combinations(tet, 3) if a in f and b in f
                )
                cell = IncidentCell(
                    simplex=tet,
                    orientation=OrientationSign.POSITIVE,
                    incident_faces=faces,
                    opposite_vertices=opposite,
                )
                hinge_to_cells.setdefault(hinge, []).append((cell, opposite))

        results = []
        for hinge, cell_data in sorted(hinge_to_cells.items()):
            cells = tuple(cd[0] for cd in cell_data)
            opposites = tuple(cd[1] for cd in cell_data)
            dual_vol = DualCellComputer.compute_dual_volume(hinge, cells, coords_provider)
            results.append(HingeTraversalResult(
                hinge=hinge,
                incident_cells=cells,
                dual_volume=dual_vol,
                opposite_vertices=opposites,
            ))
        return tuple(results)


class HingeAnalyzer:
    @staticmethod
    def analyze(hinge_result: HingeTraversalResult, coords_provider: CoordinatesProvider) -> CurvatureReport:
        dual_vol = hinge_result.dual_volume
        incident_cells = hinge_result.incident_cells
        deficit = DeficitComputer.compute_hinge_deficit(hinge_result.hinge, incident_cells, coords_provider)

        # La mesure de charnière est la mesure duale calculée (longueur d'arête en 3D)
        hinge_measure = dual_vol
        scalar_curv = deficit / dual_vol if dual_vol > 0 else 0.0

        return CurvatureReport(
            edge=hinge_result.hinge,
            incident_cells=incident_cells,
            deficit_angle=deficit,
            hinge_measure=hinge_measure,
            dual_volume=dual_vol,
            scalar_curvature=scalar_curv
        )


class ReportAssembler:
    @staticmethod
    def assemble(
        status: GeometryStatus,
        reports: Tuple[CurvatureReport, ...],
        stats: GeometryStatistics
    ) -> ReggeGeometryReport:
        total_action = ReggeActionComputer.compute_einstein_regge_action(reports)
        num_hinges = len(reports)
        total_deficit = sum(r.deficit_angle for r in reports)
        avg_curvature = (total_deficit / num_hinges) if num_hinges > 0 else 0.0
        
        max_def = max((r.deficit_angle for r in reports), default=0.0)
        min_def = min((r.deficit_angle for r in reports), default=0.0)
        
        max_len = max(stats.edge_lengths, default=0.0)
        min_len = min(stats.edge_lengths, default=0.0)

        min_gram = min(stats.gram_volumes, default=0.0)
        max_gram = max(stats.gram_volumes, default=0.0)

        return ReggeGeometryReport(
            status=status,
            total_volume=stats.total_volume,
            total_action=total_action,
            average_scalar_curvature=avg_curvature,
            maximum_deficit=max_def,
            minimum_deficit=min_def,
            total_deficit=total_deficit,
            max_edge_length=max_len,
            min_edge_length=min_len,
            num_hinges_analyzed=num_hinges,
            num_simplices=stats.num_simplices,
            num_degenerate_simplices_ignored=stats.num_degenerate_simplices_ignored,
            min_gram_volume=min_gram,
            max_gram_volume=max_gram,
            curvature_reports=reports
        )


class GeometryEngine:
    def __init__(self, psge_certificate, coords_provider: CoordinatesProvider, metric: MetricType = MetricType.EUCLIDEAN, tensor: Optional[MetricTensor] = None):
        self.certificate = psge_certificate
        self.coords = coords_provider
        self.metric = metric
        if tensor is not None:
            self.tensor = tensor
        else:
            # Infer dimension from the first available vertex coordinate
            vertices = coords_provider.all_vertices()
            dim = len(next(iter(vertices.values()))) if vertices else 4
            self.tensor = MetricTensor.minkowski(dim) if metric == MetricType.LORENTZIAN else MetricTensor.euclidean(dim)

    def run(self) -> ReggeGeometryReport:
        if not self.certificate.topological_certificate.boundary_validation:
            raise TopologyError("Échec : Le certificat topologique indique une frontière invalide ou non certifiée.")

        try:
            # Récupération propre via la structure GeometryStatistics
            stats = GeometryStatisticsCollector.collect(
                self.certificate, self.coords, self.tensor, self.metric
            )

            hinge_results = MeshTraversal.extract_hinges_and_cells(self.certificate, self.coords)
            reports_list = [HingeAnalyzer.analyze(hr, self.coords) for hr in hinge_results]
            reports_tuple = tuple(reports_list)

            return ReportAssembler.assemble(
                status=GeometryStatus.COMPUTED,
                reports=reports_tuple,
                stats=stats
            )

        except (TopologyError, MetricError, GeometryError) as exc:
            raise exc
        except Exception as exc:
            raise GeometryError("Échec inattendu du calcul géométrique dans le moteur d'orchestration.") from exc


