# 5. OPÉRATEURS GÉOMÉTRIQUES DÉCOUPLÉS
# ==========================================
class BarycentricDualCell:
    def compute_measure(self, edge: Tuple[int, int], incident_cells: Tuple[IncidentCell, ...], coords_provider: CoordinatesProvider, tensor: MetricTensor) -> float:
        if coords_provider is None: 
            return 1.0
        a, b = edge
        pa = coords_provider.vertex(a)
        pb = coords_provider.vertex(b)
        edge_vec = pb - pa
        
        if tensor.norm2(edge_vec) < 1e-15: 
            return 0.0
            
        dual_area_sum = 0.0
        for cell in incident_cells:
            tet_coords = [coords_provider.vertex(v) for v in cell.simplex]
            tet_barycenter = sum(tet_coords) / len(tet_coords)
            others = [v for v in cell.simplex if v != a and v != b]
            for c in others:
                pc = coords_provider.vertex(c)
                face_barycenter = (pa + pb + pc) / 3.0
                mid_ab = 0.5 * (pa + pb)
                v1 = face_barycenter - mid_ab
                v2 = tet_barycenter - mid_ab
                
                triangle_area = tensor.gram_area(v1, v2)
                dual_area_sum += triangle_area
                
        return float(dual_area_sum)

class SimplexVolume:
    @staticmethod
    def compute_volume(coords, tensor: MetricTensor, strict: bool = True) -> SimplexVolumeResult:
        v0 = coords[0]
        vectors = [v - v0 for v in coords[1:]]
        dim = len(vectors)
        gram = tensor.gram_matrix(vectors)
        
        rank = np.linalg.matrix_rank(gram)
        if rank < dim:
            if strict: 
                raise GeometryError("Simplexe dégénéré rencontré.")
            return SimplexVolumeResult(0.0, 0.0, GramSignature.DEGENERATE, False)
            
        det = float(np.linalg.det(gram))
        if det <= 0:
            if strict:
                raise GeometryError(f"Déterminant de Gram non strictement positif ({det:.6e}).")
            return SimplexVolumeResult(0.0, det, GramSignature.DEGENERATE, False)
            
        return SimplexVolumeResult(float(np.sqrt(det) / factorial(dim)), det, GramSignature.EUCLIDEAN, True)

class DeficitComputer:
    @staticmethod
    def _dihedral_at_hinge(cell: IncidentCell, hinge: Tuple[int, int], coords_provider: CoordinatesProvider, tensor: MetricTensor) -> float:
        a, b = hinge
        others = [v for v in cell.simplex if v not in (a, b)]
        pa, pb = coords_provider.vertex(a), coords_provider.vertex(b)
        pc, pd = coords_provider.vertex(others[0]), coords_provider.vertex(others[1])
        
        edge = pb - pa
        vc = tensor.project_orthogonal(pc - pa, edge)
        vd = tensor.project_orthogonal(pd - pa, edge)
        
        nc = tensor.norm(vc)
        nd = tensor.norm(vd)
        
        if nc < 1e-12 or nd < 1e-12:
            return 0.0
            
        cos_theta = max(-1.0, min(1.0, tensor.inner(vc, vd) / (nc * nd)))
        return float(np.arccos(cos_theta))

    @classmethod
    def compute_hinge_deficit(cls, hinge: Tuple[int, int], incident_cells: Tuple[IncidentCell, ...], coords_provider: CoordinatesProvider, tensor: MetricTensor) -> float:
        return float(2.0 * np.pi - sum(cls._dihedral_at_hinge(cell, hinge, coords_provider, tensor) for cell in incident_cells))

class GeometryEngine:
    def __init__(self, cert, coords_provider, tensor: MetricTensor = None):
        self.certificate = cert
        self.coords = coords_provider
        self.tensor = tensor if tensor else MetricTensor.euclidean(3)
        self.dual_strategy = BarycentricDualCell()

    def run(self) -> ReggeGeometryReport:
        from itertools import combinations
        total_volume, num_simplices, num_ignored = 0.0, 0, 0
        edge_set, edge_lengths_list, gram_volumes_list = set(), [], []
        
        for tet in self.certificate.tetrahedra:
            num_simplices += 1
            coords = tuple(self.coords.vertex(v) for v in tet)
            vol_result = SimplexVolume.compute_volume(coords, self.tensor, strict=False)
            if not vol_result.is_valid:
                num_ignored += 1
                continue
            total_volume += vol_result.volume
            gram_volumes_list.append(vol_result.volume)
            for a, b in combinations(sorted(tet), 2):
                if (a, b) not in edge_set:
                    edge_set.add((a, b))
                    edge_lengths_list.append(self.tensor.norm(self.coords.vertex(b) - self.coords.vertex(a)))
                    
        stats = GeometryStatistics(total_volume, tuple(edge_lengths_list), tuple(gram_volumes_list), num_simplices, num_ignored)

        hinge_to_cells = {}
        for tet in self.certificate.tetrahedra:
            tet_t = tuple(tet)
            for a, b in combinations(sorted(tet_t), 2):
                faces = tuple(tuple(sorted(f)) for f in combinations(tet_t, 3) if a in f and b in f)
                opposite = tuple(v for v in tet_t if v not in (a, b))
                cell = IncidentCell(tet_t, OrientationSign.POSITIVE, faces, opposite)
                hinge_to_cells.setdefault((a, b), []).append(cell)

        reports = []
        for h, cells in sorted(hinge_to_cells.items()):
            cells_t = tuple(cells)
            topo = HingeTopologyAnalyzer.classify_link(cells_t)
            measure = self.dual_strategy.compute_measure(h, cells_t, self.coords, self.tensor)
            deficit = DeficitComputer.compute_hinge_deficit(h, cells_t, self.coords, self.tensor)
            curv = deficit / measure if measure > 0 else 0.0
            reports.append(CurvatureReport(h, cells_t, deficit, measure, measure, curv, topo))

        reports_t = tuple(reports)
        num_h = len(reports_t)
        tot_def = sum(r.deficit_angle for r in reports_t)
        
        bulk_sum = sum(r.hinge_measure * r.deficit_angle for r in reports_t if r.topology == HingeTopology.INTERIOR)
        boundary_sum = sum(r.hinge_measure * r.deficit_angle for r in reports_t if r.topology == HingeTopology.BOUNDARY)
        total_sum = sum(r.hinge_measure * r.deficit_angle for r in reports_t)

        return ReggeGeometryReport(
            GeometryStatus.COMPUTED, stats.total_volume, bulk_sum, boundary_sum, total_sum,
            tot_def / num_h if num_h > 0 else 0.0, max((r.deficit_angle for r in reports_t), default=0.0),
            min((r.deficit_angle for r in reports_t), default=0.0), tot_def,
            max(stats.edge_lengths, default=0.0), min(stats.edge_lengths, default=0.0),
            num_h, stats.num_simplices, stats.num_degenerate_simplices_ignored,
            min(stats.gram_volumes, default=0.0), max(stats.gram_volumes, default=0.0), reports_t
        )


