# ==========================================
# 2. BACKEND GÉOMÉTRIQUE TENSORIEL (MIS À NIVEAU)
# ==========================================
@dataclass(frozen=True)
class MetricTensor:
    _matrix: np.ndarray

    def __post_init__(self):
        matrix = np.array(object.__getattribute__(self, "_matrix"), dtype=float, copy=True)
        if matrix.shape[0] != matrix.shape[1]:
            raise GeometryError("La matrice métrique doit être carrée.")
        if not np.allclose(matrix, matrix.T):
            raise GeometryError("Le tenseur métrique doit être symétrique.")
        matrix.setflags(write=False)
        object.__setattr__(self, "_matrix", matrix)

    def inner(self, u: np.ndarray, v: np.ndarray) -> float:
        return float(u.T @ self._matrix @ v)

    def norm2(self, v: np.ndarray) -> float:
        return self.inner(v, v)

    def norm(self, v: np.ndarray, eps: float = 1e-12) -> float:
        val = self.norm2(v)
        if val < -eps:
            raise GeometryError(f"Norme carrée négative ({val:.6e}) incompatible avec une métrique euclidienne.")
        return float(np.sqrt(max(0.0, val)))

    def project_orthogonal(self, v: np.ndarray, direction: np.ndarray, eps: float = 1e-12) -> np.ndarray:
        d2 = self.norm2(direction)
        if abs(d2) < eps:
            return np.zeros_like(v)
        return v - (self.inner(v, direction) / d2) * direction

    def gram_matrix(self, vectors: List[np.ndarray]) -> np.ndarray:
        n = len(vectors)
        G = np.empty((n, n), dtype=float)
        for i in range(n):
            for j in range(n):
                G[i, j] = self.inner(vectors[i], vectors[j])
        return G

    def gram_area(self, u: np.ndarray, v: np.ndarray, eps: float = 1e-12) -> float:
        g11 = self.inner(u, u)
        g22 = self.inner(v, v)
        g12 = self.inner(u, v)
        gram_det = g11 * g22 - g12 * g12
        if gram_det < -eps:
            raise GeometryError(f"Gram de surface indéfini ({gram_det:.6e}).")
        return 0.5 * float(np.sqrt(max(0.0, gram_det)))

    @classmethod
    def euclidean(cls, dim: int) -> 'MetricTensor':
        return cls(np.eye(dim))


