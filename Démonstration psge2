print("="*66)
# On empile des tetras reguliers partageant l'arete (0,1), chacun tourne du
# diedre exact autour de l'axe. Comme 5*70.53 = 352.6 < 360, il RESTE un trou :
# c'est la frustration. On mesure le deficit apres avoir place autant de vrais
# tetras reguliers que possible et en mesurant la somme reelle des diedres.
dih = np.arccos(1/3)
# arete (0,1) sur l'axe z
verts2 = {0:[0,0,0], 1:[0,0,1]}
# rayon d'un sommet de tetra regulier d'arete 1 par rapport a l'axe de l'arete
# le 3e sommet d'un triangle equilateral d'arete 1 : a distance sqrt(3)/2 du milieu d'arete
R = np.sqrt(3)/2
nid = 2
ext = []
# 5 secteurs, angles 0, dih, 2dih, ... -- vrais tetras reguliers cette fois
for k in range(6):  # on met 6 sommets pour former 5 tetras adjacents
    ang = k*dih
    verts2[nid] = [R*np.cos(ang), R*np.sin(ang), 0.5]
    ext.append(nid); nid+=1
tets2 = [(0,1,ext[k],ext[k+1]) for k in range(5)]
cert2 = Certificate(tetrahedra=tuple(tets2))
coords2 = DictCoords(verts2)
engine2 = E.GeometryEngine(cert2, coords2, metric=E.MetricType.EUCLIDEAN, tensor=tensor3d)
report2 = engine2.run()
central = report2.get_report((0,1))
print(f"\nSomme des diedres autour de (0,1) = {np.degrees(2*np.pi - central.deficit_angle):.4f} deg")
print(f"Deficit de l'arete centrale       = {np.degrees(central.deficit_angle):.4f} deg")
print(f"Attendu (2pi - 5*70.53)           = {np.degrees(2*np.pi - 5*dih):.4f} deg")
