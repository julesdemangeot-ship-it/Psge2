}
tets = [(0,1,2,3)]
cert = Certificate(tetrahedra=tuple(tets))
coords = DictCoords(verts)
tensor3d = E.MetricTensor.euclidean(3)
engine = E.GeometryEngine(cert, coords, metric=E.MetricType.EUCLIDEAN, tensor=tensor3d)
report = engine.run()

print(f"\nAngle diedre theorique du tetraedre regulier : {np.degrees(np.arccos(1/3)):.6f} deg")
print("\nDeficit par arete (pour UN seul tetra, deficit = 2pi - 1*diedre) :")
for edge in sorted([(0,1),(0,2),(0,3),(1,2),(1,3),(2,3)]):
    r = report.get_report(edge)
    # pour un seul tetra, la somme des diedres = 1 diedre, donc on remonte le diedre :
    diedre = 2*np.pi - r.deficit_angle
    print(f"  arete {edge}: diedre mesure = {np.degrees(diedre):.4f} deg  (attendu 70.5288)")

# volume du tetra regulier d'arete 1 = 1/(6 sqrt2)
print(f"\nVolume total mesure : {report.total_volume:.6f}  (attendu {1/(6*np.sqrt(2)):.6f})")

