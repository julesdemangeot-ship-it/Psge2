import numpy as np
from dataclasses import dataclass
from typing import Dict
import psge_engine as E

@dataclass
class TopoCert:
    boundary_validation: bool = True
@dataclass
class Certificate:
    tetrahedra: tuple
    topological_certificate: TopoCert = None
    def __post_init__(self):
        if self.topological_certificate is None:
            self.topological_certificate = TopoCert()
class DictCoords:
    def __init__(self, verts): self._v = {k: np.asarray(val,dtype=float) for k,val in verts.items()}
    def vertex(self,v): return self._v[v]
    def tetrahedron(self,tet): return tuple(self._v[i] for i in tet)
    def edge_length(self,edge,metric,tensor):
        a,b=edge; return float(np.linalg.norm(self._v[b]-self._v[a]))
    def all_vertices(self): return dict(self._v)

print("="*66)
print("TEST : un SEUL tetraedre regulier -- verifier l'angle diedre = 70.53 deg")
print("="*66)
# tetraedre regulier canonique
s = 1.0
verts = {
    0: [0,0,0],
    1: [1,0,0],
    2: [0.5, np.sqrt(3)/2, 0],
